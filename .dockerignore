# ==== Build artifacts (regenerated during docker build) ====
backend/target/
frontend/dist/
frontend/node_modules/
frontend/.vite/
frontend/phosphoricon/

# ==== Git metadata ====
.git/
backend/.git/

# ==== Development / IDE ====
.agents/
.agent/
.vite/
.gemini/

# ==== Database & uploads (provided via volumes at runtime) ====
backend/db/
backend/uploads/
backend/backups/
backend/blog.db

# ==== Environment secrets (provided at runtime) ====
backend/.env

# ==== Large binary / archive files ====
*.zip

# ==== Logs & temp files ====
*.log

# ==== Docs (not needed for build) ====
*.md

# ==== Scripts not needed inside image ====
package.sh
backend/backup_db.sh
blog-production/
